# ============================================================
# ConversionFoxx — Environment Variables
# ============================================================
# HOW TO USE:
# 1. Copy this file and rename it to:  .env.local
# 2. Fill in your actual values below
# 3. NEVER commit .env.local to GitHub (it's already in .gitignore)
# ============================================================

# --- SUPABASE ---
# Get these from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- GEMINI AI ---
# ⚠️  IMPORTANT: This key must ONLY be set in Vercel's dashboard,
#     NOT here in the .env file when deploying.
#     For local development only, you can add it here.
# Get it from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
